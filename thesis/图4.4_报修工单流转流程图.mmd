flowchart TD
    A([开始]) --> B[用户提交报修]
    B --> C[用户查看报修记录]
    B --> D[管理员查看工单列表]
    
    D --> E[管理员处理工单]
    E --> F{工单状态}
    
    F -->|处理中| G[记录处理信息]
    F -->|已修复| H[记录完成信息]
    F -->|已关闭| I[记录关闭原因]
    
    G --> J[发送通知]
    H --> J
    I --> J
    
    J --> C
    C --> K([结束])

classDef default fill:#fff,stroke:#000